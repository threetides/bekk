{
  "name": "@threetides/bekk",
  "version": "0.2.1",
  "description": "A polished, accessible, opinionated React component library built on top of Base UI.",
  "license": "MIT",
  "author": "threetides",
  "homepage": "https://github.com/threetides/bekk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/threetides/bekk.git"
  },
  "bugs": {
    "url": "https://github.com/threetides/bekk/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/styles.css",
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/reset.css": "./dist/styles/reset.css",
    "./styles/fonts.css": "./dist/styles/fonts.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && bun run build:assets",
    "build:assets": "node scripts/build-assets.mjs",
    "build:docs": "tsc -b && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "lint": "oxlint --deny-warnings",
    "type-check": "tsc --noEmit --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run fmt && bun run lint && bun run type-check && bun run test"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "lucide-react": "^1.16.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
